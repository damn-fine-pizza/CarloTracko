{
  "name": "@carlotracko/api",
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "test": "vitest run",
    "lint": "tsc -p tsconfig.json --noEmit",
    "knex": "knex --knexfile knexfile.ts --esm",
    "migrate": "knex --knexfile knexfile.ts --esm migrate:latest"
  },
  "dependencies": {
    "@carlotracko/shared": "workspace:*",
    "@fastify/cookie": "^10.0.1",
    "@fastify/cors": "^10.0.1",
    "@fastify/jwt": "^9.0.1",
    "@fastify/rate-limit": "^10.1.0",
    "argon2": "^0.41.1",
    "dotenv": "^16.4.5",
    "fastify": "^5.0.0",
    "knex": "^3.1.0",
    "pg": "^8.13.0",
    "zod": "^3.23.8",
    "fastify-plugin": "^5.0.1"
  },
  "devDependencies": {
    "@types/node": "^22.8.2",
    "supertest": "^7.0.0",
    "tsx": "^4.19.1",
    "typescript": "^5.6.3",
    "vitest": "^2.1.4"
  }
}
